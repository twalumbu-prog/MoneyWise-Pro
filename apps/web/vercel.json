{
    "buildCommand": "pnpm build",
    "outputDirectory": "dist",
    "installCommand": "pnpm install",
    "framework": "vite",
    "rewrites": [
        {
            "source": "/api/:path*",
            "destination": "https://money-wise-pro-api.vercel.app/:path*"
        },
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ]
}